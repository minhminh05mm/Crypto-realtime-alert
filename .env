# -----------------------------------------------------------------------------
# Project
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=crypto-realtime-alert
APP_ENV=development
TZ=UTC
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# External integrations
# -----------------------------------------------------------------------------
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/!ticker@arr
CRYPTOPANIC_API_KEY=94c910ce1d310d704b2a255a87c3d842137e2656
CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/developer/v2/posts/

# -----------------------------------------------------------------------------
# Kafka / Zookeeper
# -----------------------------------------------------------------------------
ZOOKEEPER_IMAGE=confluentinc/cp-zookeeper
ZOOKEEPER_IMAGE_TAG=7.6.1
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

KAFKA_IMAGE=confluentinc/cp-kafka
KAFKA_IMAGE_TAG=7.6.1
KAFKA_BROKER_ID=1
KAFKA_EXTERNAL_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_EXTERNAL_ADVERTISED_HOST=localhost
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0
KAFKA_AUTO_CREATE_TOPICS_ENABLE=false

KAFKA_BROKER=localhost:9092
KAFKA_INTERNAL_BROKER=kafka:29092
KAFKA_TOPIC_RAW_PRICES=raw_prices
KAFKA_TOPIC_RAW_NEWS=raw_news
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_CLIENT_ID=crypto-realtime-alert-data-ingestion
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=5
KAFKA_PRODUCER_LINGER_MS=50
KAFKA_PRODUCER_BATCH_SIZE=32768
KAFKA_PRODUCER_MAX_BLOCK_MS=10000
KAFKA_PRODUCER_REQUEST_TIMEOUT_MS=30000
KAFKA_PRODUCER_DELIVERY_TIMEOUT_SECONDS=30
KAFKA_PRODUCER_STARTUP_MAX_ATTEMPTS=5
KAFKA_PRODUCER_STARTUP_BACKOFF_SECONDS=5
KAFKA_PRODUCER_COMPRESSION_TYPE=gzip
KAFKA_PRODUCER_MAX_IN_FLIGHT_REQUESTS_PER_CONNECTION=5

# -----------------------------------------------------------------------------
# Data ingestion
# -----------------------------------------------------------------------------
BINANCE_WS_RECONNECT_DELAY_SECONDS=5
BINANCE_WS_PING_INTERVAL_SECONDS=20
BINANCE_WS_PING_TIMEOUT_SECONDS=10
PRICE_LOG_INTERVAL=100

CRYPTOPANIC_FILTER_KIND=news
CRYPTOPANIC_POLL_INTERVAL_SECONDS=60
CRYPTOPANIC_PAGE_SIZE=20
HTTP_TIMEOUT_SECONDS=15

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_IMAGE=redis
REDIS_IMAGE_TAG=7.2-alpine
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_ALERT_KEY_PREFIX=crypto:alerts
REDIS_ALERT_TTL_SECONDS=900

# -----------------------------------------------------------------------------
# ClickHouse
# -----------------------------------------------------------------------------
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server
CLICKHOUSE_IMAGE_TAG=24.8
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=crypto_alert
CLICKHOUSE_USER=crypto_admin
CLICKHOUSE_PASSWORD=admin123
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_ALERTS_TABLE=market_alerts

# -----------------------------------------------------------------------------
# Stream processing
# -----------------------------------------------------------------------------
SPARK_APP_NAME=crypto-realtime-alert-stream-processing
SPARK_MASTER=local[*]
SPARK_LOCAL_IP=127.0.0.1
SPARK_LOCAL_HOSTNAME=localhost
SPARK_DRIVER_HOST=127.0.0.1
SPARK_DRIVER_BIND_ADDRESS=127.0.0.1
SPARK_SQL_SHUFFLE_PARTITIONS=4
SPARK_KAFKA_STARTING_OFFSETS=latest
SPARK_TRIGGER_INTERVAL_SECONDS=30
SPARK_OUTPUT_MODE=append
SPARK_WINDOW_DURATION=5 minutes
SPARK_WATERMARK_DELAY=10 minutes
SPARK_CHECKPOINT_DIR=/tmp/crypto-realtime-alert/checkpoints/stream_processing
SPARK_IVY_CACHE_DIR=/tmp/crypto-realtime-alert/.ivy2
SPARK_JARS_PACKAGES=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.1

FINBERT_MODEL_NAME=ProsusAI/finbert
FINBERT_MAX_LENGTH=128

ALERT_PRICE_CHANGE_THRESHOLD_PCT=2.5
ALERT_STATUS_WARNING_HIGH_VOLATILITY=WARNING_HIGH_VOLATILITY
ALERT_STATUS_NORMAL=NO_ALERT

NEWS_SYMBOL_KEYWORDS_JSON={"BTCUSDT":["BTC","BITCOIN"],"ETHUSDT":["ETH","ETHEREUM"],"BNBUSDT":["BNB","BINANCE COIN"],"SOLUSDT":["SOL","SOLANA"],"XRPUSDT":["XRP","RIPPLE"]}
